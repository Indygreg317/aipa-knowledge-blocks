{
  "index": {
    "knowledge_block_id": "KB-CARBON-001",
    "title": "Carbon Reporting Validation Block",
    "description": "Template for validating emissions reporting and sustainability submissions.",
    "version": "0.1.0",
    "domain": "carbon",
    "category": "reporting-validation",
    "tags": ["carbon", "sustainability", "emissions", "audit"],
    "owner": "sustainability-team",
    "status": "draft"
  },
  "trigger": {
    "trigger_type": "event",
    "trigger_source": "carbon-reporting-workflow",
    "trigger_conditions": ["submission_received"],
    "preconditions": ["reporting_period_open", "methodology_approved"],
    "priority": "medium"
  },
  "execution_control": {
    "requires_revalidation": true,
    "required_authority": ["sustainability-lead"],
    "authority_mode": "conditional",
    "delta_threshold": 0.2,
    "delta_mode": "tolerant",
    "evidence_freshness_window": "P90D",
    "block_on_policy_mismatch": true,
    "fail_behavior": "fallback",
    "allowed_actions": ["validate_submission", "request_review", "record_audit"],
    "prohibited_actions": ["approve_without_evidence"],
    "audit_log_required": true
  },
  "revalidation": {
    "compare_context": true,
    "compare_policy": true,
    "compare_inputs": true,
    "compare_risk_posture": true,
    "compare_evidence": true,
    "on_mismatch": "fallback"
  },
  "risk_posture": {
    "impact": "medium",
    "likelihood": 0.2,
    "uncertainty": 0.3,
    "system_state": "production",
    "exposure_window": "persistent",
    "max_allowed_score": 0.5
  },
  "logic": [
    "If reporting period is closed, block submission.",
    "If methodology is not approved, escalate.",
    "If required emissions data is missing, request review."
  ],
  "evidence": [],
  "outcomes": ["ALLOW", "BLOCK", "REQUEST_REVIEW"]
}
