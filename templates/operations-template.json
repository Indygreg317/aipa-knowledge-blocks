{
  "index": {
    "knowledge_block_id": "KB-OPS-001",
    "title": "Operations Decision Block",
    "description": "Template for validating operational actions before execution.",
    "version": "0.1.0",
    "domain": "operations",
    "category": "execution-control",
    "tags": ["operations", "runtime", "risk", "execution"],
    "owner": "operations-team",
    "status": "draft"
  },
  "trigger": {
    "trigger_type": "state_change",
    "trigger_source": "operations-system",
    "trigger_conditions": ["action_requested"],
    "preconditions": ["capacity_available", "authority_valid"],
    "priority": "high"
  },
  "execution_control": {
    "requires_revalidation": true,
    "required_authority": ["operations-manager"],
    "authority_mode": "strict",
    "delta_threshold": 0.15,
    "delta_mode": "strict",
    "evidence_freshness_window": "PT24H",
    "block_on_policy_mismatch": true,
    "fail_behavior": "block",
    "allowed_actions": ["schedule_change", "escalate", "record_audit"],
    "prohibited_actions": ["override_maintenance_window"],
    "audit_log_required": true
  },
  "revalidation": {
    "compare_context": true,
    "compare_policy": true,
    "compare_inputs": true,
    "compare_risk_posture": true,
    "compare_evidence": true,
    "on_mismatch": "block"
  },
  "risk_posture": {
    "impact": "high",
    "likelihood": 0.25,
    "uncertainty": 0.2,
    "system_state": "production",
    "exposure_window": "session",
    "max_allowed_score": 0.4
  },
  "logic": [
    "If capacity is unavailable, block execution.",
    "If maintenance conflict exists, escalate.",
    "If risk exceeds threshold, block execution."
  ],
  "evidence": [],
  "outcomes": ["ALLOW", "BLOCK", "ESCALATE"]
}
